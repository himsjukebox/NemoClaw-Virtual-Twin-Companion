# =============================================================================
# NemoClaw Virtual Twin Companion — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your NVIDIA API key.
# The NVIDIA_API_KEY is REQUIRED for ChatNVIDIA and NVIDIAEmbeddings to function.
# Obtain your key from https://build.nvidia.com/
# =============================================================================

NVIDIA_API_KEY=your_key_here
